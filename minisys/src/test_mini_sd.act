import testing

import yang.gdata as gdata

import mini.devices.ietf as ietf_dev
import mini.layers.y_0 as cfs_layer
import mini.sysspec
import stratoweave.testing as swts


def discover(devices: dict[str, gdata.Node]) -> gdata.Node:
    cfs_root = cfs_layer.root()
    cfs_root.netinfra.global_settings.asn = 123
    for idx, name in enumerate(sorted([n for n in devices.keys()])):
        dev = ietf_dev.root.from_gdata(devices[name])
        hostname = dev.system.hostname
        if hostname is None:
            raise ValueError(f"No system/hostname in input for device {name}")
        router = cfs_root.netinfra.router.create(name=hostname!, id=u64(idx+1), type="ietf")
        router.mock = True
    return cfs_root.to_gdata()


actor _test_sd_basic(t: testing.EnvT):
    swts.ServiceDiscoveryTester(t, mini.sysspec.SYSSPEC, "test/sd/basic", discover)

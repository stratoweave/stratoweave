import testing

import mini.layers.y_0 as cfs_layer
import mini.layers.y_0_oper as cfs_oper
import mini.sysspec
import stratoweave
import stratoweave.testing as swts

actor _test_netinfra1(t: testing.AsyncT):
    # Test input config
    root = cfs_layer.root()
    root.netinfra.global_settings.asn = 123
    router = root.netinfra.router.create("rtr1", 1, "ietf")
    router.mock = True

    swts.TransformTester(t, mini.sysspec.SYSSPEC, root.to_gdata())


actor _test_netinfra_router_oper(t: testing.AsyncT):
    root = cfs_layer.root()
    root.netinfra.global_settings.asn = 123
    router = root.netinfra.router.create("rtr1", 1, "ietf")
    router.mock = True

    tr = stratoweave.test_main(mini.sysspec.SYSSPEC, t.log_handler)
    var attempts = 0

    def poll():
        attempts += 1
        oper_root = cfs_oper.root.from_gdata(tr.cfs.newsession().get_data())
        r = oper_root.netinfra.router.get("rtr1")
        if r is not None:
            cd = r.state.current_datetime
            if cd is not None and cd.startswith("rfs-"):
                t.success()
                return
        if attempts >= 20:
            t.failure(ValueError("Timed out waiting for CFS router operational state"))
            return
        after 0.01: poll()

    def cont(_r: value):
        after 0: poll()

    tr.edit_config(root.to_gdata(), cont)


actor _test_l3vpn1(t: testing.AsyncT):
    root = cfs_layer.root()
    root.netinfra.global_settings.asn = 123

    router1 = root.netinfra.router.create(name="rtr1", id=1, type="ietf")
    router1.mock = True

    router2 = root.netinfra.router.create(name="rtr2", id=2, type="ietf")
    router2.mock = True

    vpn = root.l3vpn.create(
        name="blue",
        customer_name="acme",
        vpn_id=100,
        service_mtu=1600,
    )
    vpn.endpoint.create(
        device="rtr1",
        interface_name="ge-0/0/0.101",
        ipv4_address="192.0.2.1",
        prefix_length=31,
        mtu=1580,
        vlan_id=101,
        site_code="sto1",
        description="Stockholm CE",
    )
    vpn.endpoint.create(
        device="rtr2",
        interface_name="ge-0/0/0.202",
        ipv4_address="192.0.2.3",
        prefix_length=31,
        vlan_id=202,
        site_code="gbg1",
    )

    swts.TransformTester(t, mini.sysspec.SYSSPEC, root.to_gdata())

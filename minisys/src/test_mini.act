import testing

import yang.gdata as gdata
import mini.layers.y_0 as cfs_layer
import mini.sysspec
import stratoweave

NS_NETINFRA = "http://example.com/netinfra"

def q_netinfra(n: str) -> gdata.Id:
    return gdata.Id(NS_NETINFRA, n)

def _router_current_datetime(data: ?gdata.Node, router_name: str) -> ?str:
    if not isinstance(data, gdata.Container):
        return None
    d = data!
    netinfra = d.children.get(q_netinfra("netinfra"))
    if isinstance(netinfra, gdata.Container):
        routers = netinfra.children.get(q_netinfra("router"))
        if isinstance(routers, gdata.List):
            for elem in routers.elements:
                if not isinstance(elem, gdata.Container):
                    continue
                name_leaf = elem.children.get(q_netinfra("name"))
                if isinstance(name_leaf, gdata.Leaf):
                    name_val = name_leaf.val
                    if not (isinstance(name_val, str) and name_val == router_name):
                        continue
                    state = elem.children.get(q_netinfra("state"))
                    if isinstance(state, gdata.Container):
                        current_datetime = state.children.get(q_netinfra("current-datetime"))
                        if isinstance(current_datetime, gdata.Leaf):
                            val = current_datetime.val
                            if isinstance(val, str):
                                return val
    return None


actor _test_netinfra1(t: testing.AsyncT):
    # Test input config
    root = cfs_layer.root()
    root.netinfra.global_settings.asn = 123
    router = root.netinfra.router.create("rtr1", 1, "ietf")
    router.mock = True

    input_config = root.to_gdata()

    tr = stratoweave.test_main(mini.sysspec.SYSSPEC, t.log_handler)

    def cont(_r: value):
        t.success(tr.device_adata_snapshot())

    tr.edit_config(input_config, cont)

    def fail():
        t.failure(ValueError())
    after 2.5: fail()


actor _test_netinfra_router_oper(t: testing.AsyncT):
    root = cfs_layer.root()
    root.netinfra.global_settings.asn = 123
    router = root.netinfra.router.create("rtr1", 1, "ietf")
    router.mock = True

    tr = stratoweave.test_main(mini.sysspec.SYSSPEC, t.log_handler)
    var attempts = 0

    def poll():
        attempts += 1
        current_datetime = _router_current_datetime(tr.cfs.newsession().get_data(), "rtr1")
        if current_datetime is not None:
            t.success()
            return
        if attempts >= 20:
            t.failure(ValueError("Timed out waiting for CFS router operational state"))
            return
        after 0.01: poll()

    def cont(_r: value):
        after 0: poll()

    tr.edit_config(root.to_gdata(), cont)


actor _test_l3vpn1(t: testing.AsyncT):
    root = cfs_layer.root()
    root.netinfra.global_settings.asn = 123

    router1 = root.netinfra.router.create(name="rtr1", id=1, type="ietf")
    router1.mock = True

    router2 = root.netinfra.router.create(name="rtr2", id=2, type="ietf")
    router2.mock = True

    vpn = root.l3vpn.create(
        name="blue",
        customer_name="acme",
        vpn_id=100,
        service_mtu=1600,
    )
    vpn.endpoint.create(
        device="rtr1",
        interface_name="ge-0/0/0.101",
        ipv4_address="192.0.2.1",
        prefix_length=31,
        mtu=1580,
        vlan_id=101,
        site_code="sto1",
        description="Stockholm CE",
    )
    vpn.endpoint.create(
        device="rtr2",
        interface_name="ge-0/0/0.202",
        ipv4_address="192.0.2.3",
        prefix_length=31,
        vlan_id=202,
        site_code="gbg1",
    )

    input_config = root.to_gdata()

    tr = stratoweave.test_main(mini.sysspec.SYSSPEC, t.log_handler)

    def cont(_r: value):
        t.success(tr.device_adata_snapshot())

    tr.edit_config(input_config, cont)

    def fail():
        t.failure(ValueError())
    after 2.5: fail()

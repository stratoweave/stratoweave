        DLeafList(module='ietf-yang-library', namespace='urn:ietf:params:xml:ns:yang:ietf-yang-library', prefix='yanglib', name='location', config=False, description='Contains a URL that represents the YANG schema\nresource for this module or submodule.\n\nThis leaf will only be present if there is a URL\navailable for retrieval of the schema for this entry.', min_elements=0, ordered_by='system', type_=DTypeString(name='inet:uri', description="The uri type represents a Uniform Resource Identifier\n(URI) as defined by STD 66.\n\nObjects using the uri type MUST be in US-ASCII encoding,\nand MUST be normalized as described by RFC 3986 Sections\n6.2.1, 6.2.2.1, and 6.2.2.2.  All unnecessary\npercent-encoding is removed, and all case-insensitive\ncharacters are set to lowercase except for hexadecimal\ndigits, which are normalized to uppercase as described in\nSection 6.2.2.1.\n\nThe purpose of this normalization is to help provide\nunique URIs.  Note that this normalization is not\nsufficient to provide uniqueness.  Two URIs that are\ntextually distinct after this normalization may still be\nequivalent.\n\nObjects using the uri type may restrict the schemes that\nthey permit.  For example, 'data:' and 'urn:' schemes\nmight not be appropriate.\n\nA zero-length URI is not a valid URI.  This can be used to\nexpress 'URI absent' where required.\n\nIn the value set and its semantics, this type is equivalent\nto the Uri SMIv2 textual convention defined in RFC 5017.", reference='RFC 3986: Uniform Resource Identifier (URI): Generic Syntax\nRFC 3305: Report from the Joint W3C/IETF URI Planning Interest\n          Group: Uniform Resource Identifiers (URIs), URLs,\n          and Uniform Resource Names (URNs): Clarifications\n          and Recommendations\nRFC 5017: MIB Textual Conventions for Uniform Resource\n          Identifiers (URIs)', exts=[], builtin_type='string', default=None, length=None, patterns=[]))
    ])
])

SRC_DNODE_CHILD_1 = DList(module='ietf-yang-library', namespace='urn:ietf:params:xml:ns:yang:ietf-yang-library', prefix='yanglib', name='module-set', key=['name'], config=False, description='A set of modules that may be used by one or more schemas.\n\nA module set does not have to be referentially complete,\ni.e., it may define modules that contain import statements\nfor other modules not included in the module set.', min_elements=0, ordered_by='system', children=[SRC_DNODE_CHILD_2, SRC_DNODE_CHILD_3, SRC_DNODE_CHILD_4])

SRC_DNODE_CHILD_5 = DList(module='ietf-yang-library', namespace='urn:ietf:params:xml:ns:yang:ietf-yang-library', prefix='yanglib', name='schema', key=['name'], config=False, description='A datastore schema that may be used by one or more\ndatastores.\n\nThe schema must be valid and referentially complete, i.e.,\nit must contain modules to satisfy all used import\nstatements for all modules specified in the schema.', min_elements=0, ordered_by='system', children=[
    DLeaf(module='ietf-yang-library', namespace='urn:ietf:params:xml:ns:yang:ietf-yang-library', prefix='yanglib', name='name', config=False, description='An arbitrary name of the schema.', mandatory=False, type_=DTypeString(name='string', description=None, reference=None, exts=[], builtin_type='string', default=None, length=None, patterns=[])),
    DLeafList(module='ietf-yang-library', namespace='urn:ietf:params:xml:ns:yang:ietf-yang-library', prefix='yanglib', name='module-set', config=False, description='A set of module-sets that are included in this schema.\nIf a non-import-only module appears in multiple module\nsets, then the module revision and the associated features\nand deviations must be identical.', min_elements=0, ordered_by='system', type_=DTypeLeafref(name='leafref', description=None, reference=None, exts=[], builtin_type='leafref', default=None, path=yang.xpath.AbsoluteLocationPath([yang.xpath.NodeTestStep(None, 'yang-library', []), yang.xpath.NodeTestStep(None, 'module-set', []), yang.xpath.NodeTestStep(None, 'name', [])]), require_instance=False, target_type=DTypeString(name='string', description=None, reference=None, exts=[], builtin_type='string', default=None, length=None, patterns=[])))
])

SRC_DNODE_CHILD_6 = DList(module='ietf-yang-library', namespace='urn:ietf:params:xml:ns:yang:ietf-yang-library', prefix='yanglib', name='datastore', key=['name'], config=False, description='A datastore supported by this server.\n\nEach datastore indicates which schema it supports.\n\nThe server MUST instantiate one entry in this list per\nspecific datastore it supports.\nEach datastore entry with the same datastore schema SHOULD\nreference the same schema.', min_elements=0, ordered_by='system', children=[
    DLeaf(module='ietf-yang-library', namespace='urn:ietf:params:xml:ns:yang:ietf-yang-library', prefix='yanglib', name='name', config=False, description='The identity of the datastore.', mandatory=False, type_=DTypeIdentityref(name='ds:datastore-ref', description='A datastore identity reference.', reference=None, exts=[], builtin_type='identityref', default=None, identity_bases=[_base_ietf_datastores_datastore], identities=_identities)),
    DLeaf(module='ietf-yang-library', namespace='urn:ietf:params:xml:ns:yang:ietf-yang-library', prefix='yanglib', name='schema', config=False, description='A reference to the schema supported by this datastore.\nAll non-import-only modules of the schema are implemented\nwith their associated features and deviations.', mandatory=True, type_=DTypeLeafref(name='leafref', description=None, reference=None, exts=[], builtin_type='leafref', default=None, path=yang.xpath.AbsoluteLocationPath([yang.xpath.NodeTestStep(None, 'yang-library', []), yang.xpath.NodeTestStep(None, 'schema', []), yang.xpath.NodeTestStep(None, 'name', [])]), require_instance=False, target_type=DTypeString(name='string', description=None, reference=None, exts=[], builtin_type='string', default=None, length=None, patterns=[])))
])

SRC_DNODE_CHILD_7 = DLeaf(module='ietf-yang-library', namespace='urn:ietf:params:xml:ns:yang:ietf-yang-library', prefix='yanglib', name='content-id', config=False, description="A server-generated identifier of the contents of the\n'/yang-library' tree.  The server MUST change the value of\nthis leaf if the information represented by the\n'/yang-library' tree, except '/yang-library/content-id', has\nchanged.", mandatory=True, type_=DTypeString(name='string', description=None, reference=None, exts=[], builtin_type='string', default=None, length=None, patterns=[]))

SRC_DNODE_CHILD_0 = DContainer(module='ietf-yang-library', namespace='urn:ietf:params:xml:ns:yang:ietf-yang-library', prefix='yanglib', name='yang-library', config=False, description='Container holding the entire YANG library of this server.', presence=False, children=[SRC_DNODE_CHILD_1, SRC_DNODE_CHILD_5, SRC_DNODE_CHILD_6, SRC_DNODE_CHILD_7])

SRC_DNODE_IDENTITY_0 = DIdentity(module='ietf-datastores', namespace='urn:ietf:params:xml:ns:yang:ietf-datastores', prefix='ds', name='datastore')

SRC_DNODE_IDENTITY_1 = DIdentity(module='ietf-datastores', namespace='urn:ietf:params:xml:ns:yang:ietf-datastores', prefix='ds', name='conventional', base=[
        DIdentity(module='ietf-datastores', namespace='urn:ietf:params:xml:ns:yang:ietf-datastores', prefix='ds', name='datastore')
    ])

SRC_DNODE_IDENTITY_2 = DIdentity(module='ietf-datastores', namespace='urn:ietf:params:xml:ns:yang:ietf-datastores', prefix='ds', name='running', base=[
        DIdentity(module='ietf-datastores', namespace='urn:ietf:params:xml:ns:yang:ietf-datastores', prefix='ds', name='conventional', base=[
                DIdentity(module='ietf-datastores', namespace='urn:ietf:params:xml:ns:yang:ietf-datastores', prefix='ds', name='datastore')
            ])
    ])

SRC_DNODE_IDENTITY_3 = DIdentity(module='ietf-datastores', namespace='urn:ietf:params:xml:ns:yang:ietf-datastores', prefix='ds', name='candidate', base=[
        DIdentity(module='ietf-datastores', namespace='urn:ietf:params:xml:ns:yang:ietf-datastores', prefix='ds', name='conventional', base=[
                DIdentity(module='ietf-datastores', namespace='urn:ietf:params:xml:ns:yang:ietf-datastores', prefix='ds', name='datastore')
            ])
    ])

SRC_DNODE_IDENTITY_4 = DIdentity(module='ietf-datastores', namespace='urn:ietf:params:xml:ns:yang:ietf-datastores', prefix='ds', name='startup', base=[
        DIdentity(module='ietf-datastores', namespace='urn:ietf:params:xml:ns:yang:ietf-datastores', prefix='ds', name='conventional', base=[
                DIdentity(module='ietf-datastores', namespace='urn:ietf:params:xml:ns:yang:ietf-datastores', prefix='ds', name='datastore')
            ])
    ])

SRC_DNODE_IDENTITY_5 = DIdentity(module='ietf-datastores', namespace='urn:ietf:params:xml:ns:yang:ietf-datastores', prefix='ds', name='intended', base=[
        DIdentity(module='ietf-datastores', namespace='urn:ietf:params:xml:ns:yang:ietf-datastores', prefix='ds', name='conventional', base=[
                DIdentity(module='ietf-datastores', namespace='urn:ietf:params:xml:ns:yang:ietf-datastores', prefix='ds', name='datastore')
            ])

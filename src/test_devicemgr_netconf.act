actor _test_subscription_manager_declare(t: testing.EnvT):
    """Declarative subscription manager over NETCONF mock subscriptions."""
    mock_current_datetime_1 = "2026-02-21T10:11:12Z"
    mock_current_datetime_2 = "2026-02-21T10:11:13Z"
    mock_boot_datetime = "2025-12-31T00:00:00Z"

    var done = False
    var phase = 0
    var mock_server: ?swna.NetconfMockServer = None
    var subs: ?ygdata.SubscriptionManager = None
    var dst: ?ygdata.Dst = None

    def noop_on_reconf(name: str):
        pass
    dev = new_netconf_mock_device_mgr(t, "dev-subs", noop_on_reconf)

    def close_subs():
        if subs is not None:
            subs.close()

    def fail(msg: str):
        if done:
            return
        done = True
        close_subs()
        t.failure(ValueError(msg))

    def succeed():
        if done:
            return
        done = True
        close_subs()
        t.success()

    def on_update(n: ?ygdata.Node, err: ?Exception):
        if done:
            return
        if err is not None:
            fail("Subscription manager update error: {err}")
            return

        dt = _current_datetime_from_tree(n)
        has_boot = _has_boot_datetime(n)

        if phase == 0 and dt == mock_current_datetime_1 and has_boot:
            phase = 1
            declare_current_only()
            return

        if phase == 1 and dt == mock_current_datetime_1 and not has_boot:
            phase = 2
            ygdata.expect(mock_server, "mock server").set_oper_ds(_mock_oper_ds(mock_current_datetime_2, mock_boot_datetime))
            return

        if phase == 2 and dt == mock_current_datetime_2 and not has_boot:
            succeed()
            return

    def declare_both():
        want = {
            ygdata.expect(dst, "subscription destination").deliver({
                ygdata.SubscriptionSpec(_current_datetime_filter(), period=0.05),
                ygdata.SubscriptionSpec(_boot_datetime_filter(), period=0.05),
            })
        }
        ygdata.expect(subs, "subscription manager").declare(want)

    def declare_current_only():
        want = {
            ygdata.expect(dst, "subscription destination").deliver({
                ygdata.SubscriptionSpec(_current_datetime_filter(), period=0.05)
            })
        }
        ygdata.expect(subs, "subscription manager").declare(want)

    def start():
        adapter = dev.get_adapter()
        if isinstance(adapter, swna.NetconfAdapter):
            ms0 = adapter.get_mock_server()
            if ms0 is None:
                fail("Expected NetconfMockServer from NetconfAdapter")
                return
            ms = ygdata.expect(ms0, "mock server")
            mock_server = ms
            ms.set_oper_ds(_mock_oper_ds(mock_current_datetime_1, mock_boot_datetime))
            dst = ygdata.Dst(on_update)
            subs = ygdata.SubscriptionManager(dev.tree_provider(), "test-subscription-manager")
            declare_both()
        else:
            fail("Expected NetconfAdapter from DeviceMgr")

    start()

    after 2.0: fail("Timed out waiting for declarative subscription manager updates")


actor _test_subscription_manager_idempotent(t: testing.EnvT):
    """Redeclaring the same subscriptions is a no-op."""
    mock_current_datetime = "2026-02-21T10:11:12Z"
    mock_boot_datetime = "2025-12-31T00:00:00Z"

    var done = False
    var updates = 0
    var subs: ?ygdata.SubscriptionManager = None
    var dst: ?ygdata.Dst = None

    def noop_on_reconf(name: str):
        pass
    dev = new_netconf_mock_device_mgr(t, "dev-subs-idempotent", noop_on_reconf)

    def close_subs():
        if subs is not None:
            subs.close()

    def fail(msg: str):
        if done:
            return
        done = True
        close_subs()
        t.failure(ValueError(msg))

    def succeed():
        if done:
            return
        done = True
        close_subs()
        t.success()

    def on_update(n: ?ygdata.Node, err: ?Exception):
        if done:
            return
        if err is not None:
            fail("Subscription manager update error: {err}")
            return

        updates += 1
        if updates > 1:
            fail("Unexpected extra subscription update: {updates}")
            return

        dt = _current_datetime_from_tree(n)
        has_boot = _has_boot_datetime(n)
        if dt != mock_current_datetime:
            fail("Unexpected current datetime: {dt}")
            return
        if has_boot:
            fail("Unexpected boot datetime in filtered update")
            return

        declare_current_only()
        after 0.15: succeed()

    def declare_current_only():
        want = {
            ygdata.expect(dst, "subscription destination").deliver({
                ygdata.SubscriptionSpec(_current_datetime_filter(), period=0.05)
            })
        }
        ygdata.expect(subs, "subscription manager").declare(want)

    def start():
        adapter = dev.get_adapter()
        if isinstance(adapter, swna.NetconfAdapter):
            ms0 = adapter.get_mock_server()
            if ms0 is None:
                fail("Expected NetconfMockServer from NetconfAdapter")
                return
            ms = ygdata.expect(ms0, "mock server")
            ms.set_oper_ds(_mock_oper_ds(mock_current_datetime, mock_boot_datetime))
            dst = ygdata.Dst(on_update)
            subs = ygdata.SubscriptionManager(dev.tree_provider(), "test-subscription-manager-idempotent")
            declare_current_only()
        else:
            fail("Expected NetconfAdapter from DeviceMgr")

    start()

    after 2.0: fail("Timed out waiting for idempotent subscription manager test")
